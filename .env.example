# 환경변수 설정 (키 없어도 mock 데이터로 동작)
# 아래 값을 실제 키로 교체하세요

# 한국관광공사 TourAPI (https://www.data.go.kr)
TOUR_API_KEY=YOUR_TOUR_API_KEY_HERE

# 카카오맵 JavaScript 앱 키 (https://developers.kakao.com)
KAKAO_MAP_KEY=YOUR_KAKAO_MAP_KEY_HERE

# Google Gemini API (https://aistudio.google.com) — 없으면 저장된 추천 이유만 사용하고 신규 경로 이유는 생략
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# 기상청 단기예보 API (https://www.data.go.kr) — 없으면 날씨 연동 생략
WEATHER_KEY=YOUR_WEATHER_KEY_HERE

# 배포 URL로 변경 (콤마로 여러 개 지정 가능)
# Railway: https://your-app.up.railway.app
# HuggingFace Spaces: https://your-space.hf.space
# 로컬 개발은 기본값(localhost:8000)으로 동작하므로 설정 불필요
ALLOWED_ORIGINS=https://your-app.up.railway.app

# HuggingFace Spaces 배포 시 포트 (기본값: 8000, HF는 7860)
# PORT=7860
